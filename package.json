{
  "name": "huk",
  "version": "0.1.0",
  "description": "A simple CLI to capture, inspect, forward and replay webhook requests (a tiny usewebhook.com).",
  "type": "module",
  "bin": {
    "huk": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup src/cli.ts --format esm --clean --target node20",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "webhook",
    "cli",
    "http",
    "debug",
    "tunnel",
    "ngrok"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
